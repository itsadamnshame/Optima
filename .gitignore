# ==========================================
# 1. OPTIMA SPECIFIC DATA & STORAGE
# (CRITICAL: Never commit client sales data!)
# ==========================================
raw_sales_data/
backend_storage/
*.csv
*.xlsx
*.xls
*.json
!package.json
!package-lock.json
!frontend/package.json
!frontend/package-lock.json
# If you need to keep the folder structures but ignore the files inside them, 
# you can use these two lines instead of the folder names above:
# raw_sales_data/*
# !raw_sales_data/.gitkeep
# backend_storage/*
# !backend_storage/.gitkeep

# ==========================================
# 2. PYTHON & DATA SCIENCE BACKEND
# ==========================================
