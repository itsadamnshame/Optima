__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
.env_python/

# Jupyter Notebooks (Experiments folder)
.ipynb_checkpoints/

# PyInstaller (If you build local executables later)
build/
dist/
*.spec

